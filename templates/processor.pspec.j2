<?xml version="1.0" encoding="UTF-8"?>
<!-- Auto-generated processor spec for {{ meta.name }} -->
<processor_spec>
  <properties>
    <property key="addressesDoNotAppearDirectlyInCode" value="true"/>
  </properties>

  <programcounter register="{{ pc_register }}"/>

  <context_data>
    <context_set space="ram">
      <set name="TMode" val="0"/>
    </context_set>
  </context_data>

  <register_data>
{% for reg in registers %}
    <register name="{{ reg.name }}" rename="{{ reg.name }}" group="General Purpose"/>
{% endfor %}
  </register_data>
</processor_spec>
