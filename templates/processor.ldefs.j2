<?xml version="1.0" encoding="UTF-8"?>
<!-- Auto-generated language definitions for {{ meta.name }} -->
<language_definitions>
{% if meta.endian == "bi" %}
  <language processor="{{ processor_name }}"
            endian="little"
            size="{{ meta.word_size_bits }}"
            variant="{{ meta.variant }}"
            version="1.0"
            slafile="{{ processor_name }}_le.sla"
            processorspec="{{ processor_name }}.pspec"
            id="{{ processor_name }}:LE:{{ meta.word_size_bits }}:{{ meta.variant }}">
    <description>{{ meta.name }} little-endian (auto-generated by rosetta)</description>
    <compiler name="default" spec="{{ processor_name }}.cspec" id="default"/>
  </language>
  <language processor="{{ processor_name }}"
            endian="big"
            size="{{ meta.word_size_bits }}"
            variant="{{ meta.variant }}"
            version="1.0"
            slafile="{{ processor_name }}_be.sla"
            processorspec="{{ processor_name }}.pspec"
            id="{{ processor_name }}:BE:{{ meta.word_size_bits }}:{{ meta.variant }}">
    <description>{{ meta.name }} big-endian (auto-generated by rosetta)</description>
    <compiler name="default" spec="{{ processor_name }}.cspec" id="default"/>
  </language>
{% else %}
  <language processor="{{ processor_name }}"
            endian="{{ meta.endian }}"
            size="{{ meta.word_size_bits }}"
            variant="{{ meta.variant }}"
            version="1.0"
            slafile="{{ processor_name }}.sla"
            processorspec="{{ processor_name }}.pspec"
            id="{{ processor_name }}:{{ 'LE' if meta.endian == 'little' else 'BE' }}:{{ meta.word_size_bits }}:{{ meta.variant }}">
    <description>{{ meta.name }} (auto-generated by rosetta)</description>
    <compiler name="default" spec="{{ processor_name }}.cspec" id="default"/>
  </language>
{% endif %}
</language_definitions>
