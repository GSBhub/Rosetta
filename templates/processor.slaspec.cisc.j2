# {{ processor_name }}.slaspec — {{ meta.name }} (opcode-table encoding)
# Auto-generated by rosetta from ISA manual via opcode_map pass.

define endian={{ meta.endian if meta.endian != "bi" else "little" }};
define alignment={{ meta.alignment }};

define space ram      type=ram_space      size={{ (meta.word_size_bits // 8) }} wordsize=1 default;
define space register type=register_space size=4;

{# ── Registers ─────────────────────────────────────────────────────────── #}
{% set ns = namespace(offset=0) %}
{% for reg in registers %}
define register offset=0x{{ "%02X" | format(ns.offset) }} size={{ (reg.size_bits // 8) }} [ {{ reg.name }} ];
{% set ns.offset = ns.offset + (reg.size_bits // 8) %}
{% endfor %}

{# ── Tokens ────────────────────────────────────────────────────────────── #}
define token opbyte(8)   opcode=(0,7);
define token t_b1(8)     b1=(0,7);
define token t_b1s(8)    sb1=(0,7) signed;
define token t_w1(16)    w1=(0,15);
define token t_w1s(16)   sw1=(0,15) signed;
define token t_l1(24)    l1=(0,23);

{# ── Relative-branch subtables ─────────────────────────────────────────── #}
Rel8:  target  is sb1   [ target = inst_next + sb1;  ]  { export *[ram]:{{ meta.word_size_bits // 8 }} target; }
Rel16: target  is sw1   [ target = inst_next + sw1;  ]  { export *[ram]:{{ meta.word_size_bits // 8 }} target; }

{# ── Addressing-mode helpers ───────────────────────────────────────────── #}
{#
   _mode_tokens(mode)  → the "; token" chain appended to the is-clause
   _mode_display(mode) → the display string fragment
   _mode_body(mnem, mode) → stub pcode body
#}
{% macro _mode_tokens(mode) -%}
{%- if mode in ("imp", "implied", "acc", "accumulator", "") -%}
{%- elif mode in ("imm", "#imm", "imm8", "#imm8") -%}; b1
{%- elif mode in ("imm16", "#imm16") -%}; w1
{%- elif mode in ("dp", "zp", "direct", "direct page") -%}; b1
{%- elif mode in ("dp,X", "zp,X", "direct,X") -%}; b1
{%- elif mode in ("dp,Y", "zp,Y", "direct,Y") -%}; b1
{%- elif mode in ("(dp)", "(zp)", "indirect") -%}; b1
{%- elif mode in ("(dp,X)", "(zp,X)", "dp indexed indirect", "indexed indirect") -%}; b1
{%- elif mode in ("(dp),Y", "(zp),Y", "indirect indexed") -%}; b1
{%- elif mode in ("abs", "absolute", "abs16") -%}; w1
{%- elif mode in ("abs,X", "absolute,X", "absolute+X") -%}; w1
{%- elif mode in ("abs,Y", "absolute,Y", "absolute+Y") -%}; w1
{%- elif mode in ("(abs)", "(absolute)", "absolute indirect") -%}; w1
{%- elif mode in ("(abs,X)", "(absolute,X)", "absolute indirect indexed") -%}; w1
{%- elif mode in ("rel", "rel8", "relative", "pcr8") -%}; Rel8
{%- elif mode in ("rel16", "pcr16", "long relative") -%}; Rel16
{%- elif mode in ("long", "abs24", "absolute long", "long absolute") -%}; l1
{%- elif mode in ("long,X", "abs24,X", "absolute long,X") -%}; l1
{%- elif mode in ("sr", "stk", "stack relative", "stack,S") -%}; b1
{%- elif mode in ("(sr),Y", "(stk),Y", "stack relative indirect indexed") -%}; b1
{%- elif mode in ("mvn", "mvp", "block move") -%}; b1; b1
{%- elif mode in ("sig", "signature") -%}; b1
{%- else -%}; b1
{%- endif -%}
{%- endmacro %}

{% macro _mode_display(mode) -%}
{%- if mode in ("imp", "implied", "") -%}
{%- elif mode in ("acc", "accumulator") -%} "A"
{%- elif mode in ("imm", "#imm", "imm8", "#imm8") -%} "#"b1
{%- elif mode in ("imm16", "#imm16") -%} "#"w1
{%- elif mode in ("dp", "zp", "direct", "direct page") -%} b1
{%- elif mode in ("dp,X", "zp,X") -%} b1,"X"
{%- elif mode in ("dp,Y", "zp,Y") -%} b1,"Y"
{%- elif mode in ("(dp)", "(zp)", "indirect") -%} (b1)
{%- elif mode in ("(dp,X)", "(zp,X)", "dp indexed indirect", "indexed indirect") -%} (b1,"X")
{%- elif mode in ("(dp),Y", "(zp),Y", "indirect indexed") -%} (b1),"Y"
{%- elif mode in ("abs", "absolute", "abs16") -%} w1
{%- elif mode in ("abs,X", "absolute,X", "absolute+X") -%} w1,"X"
{%- elif mode in ("abs,Y", "absolute,Y", "absolute+Y") -%} w1,"Y"
{%- elif mode in ("(abs)", "(absolute)", "absolute indirect") -%} (w1)
{%- elif mode in ("(abs,X)", "(absolute,X)", "absolute indirect indexed") -%} (w1,"X")
{%- elif mode in ("rel", "rel8", "relative", "pcr8") -%} Rel8
{%- elif mode in ("rel16", "pcr16", "long relative") -%} Rel16
{%- elif mode in ("long", "abs24", "absolute long", "long absolute") -%} l1
{%- elif mode in ("long,X", "abs24,X") -%} l1,"X"
{%- elif mode in ("sr", "stk", "stack relative", "stack,S") -%} b1,"S"
{%- elif mode in ("(sr),Y", "(stk),Y") -%} (b1,"S"),"Y"
{%- elif mode in ("mvn", "mvp", "block move") -%} b1,b1
{%- elif mode in ("sig", "signature") -%} b1
{%- else -%} b1
{%- endif -%}
{%- endmacro %}

{% macro _mode_body(mnem, mode) -%}
{%- set m = mnem | upper -%}
{%- if m in ("NOP", "SEC", "CLC", "SEI", "CLI", "CLV", "SED", "CLD", "STP", "WAI", "WIT") -%}local tmp:1 = 0;
{%- elif m in ("RTI", "RTS", "RTL") -%}return [0];
{%- elif m == "JMP" and mode in ("abs", "absolute") -%}goto w1;
{%- elif m == "JMP" and mode in ("(abs)", "absolute indirect") -%}local ptr:{{ meta.word_size_bits // 8 }} = *[ram]:{{ meta.word_size_bits // 8 }} w1; goto [ptr];
{%- elif m in ("JSR", "JSL") and mode in ("abs", "absolute") -%}call w1;
{%- elif m in ("BRA", "BCC", "BCS", "BEQ", "BNE", "BMI", "BPL", "BVC", "BVS") -%}goto Rel8;
{%- elif m == "BRL" -%}goto Rel16;
{%- else -%}local tmp:2 = 0;
{%- endif -%}
{%- endmacro %}

{# ── Constructors ──────────────────────────────────────────────────────── #}
{% for entry in opcode_map %}
{%- if entry.mnemonic != "UNK" %}
{%- set display = _mode_display(entry.mode) %}
{%- set tokens  = _mode_tokens(entry.mode) %}
{%- set body    = _mode_body(entry.mnemonic, entry.mode) %}
{%- if entry.prefix is not none %}
:{{ entry.mnemonic }}{% if display %} {{ display }}{% endif %}  is opcode=0x{{ "%02X" | format(entry.prefix) }}; b1=0x{{ "%02X" | format(entry.opcode) }}{{ tokens }}  { {{ body }} }
{% else %}
:{{ entry.mnemonic }}{% if display %} {{ display }}{% endif %}  is opcode=0x{{ "%02X" | format(entry.opcode) }}{{ tokens }}  { {{ body }} }
{% endif %}
{%- endif %}
{% endfor %}
