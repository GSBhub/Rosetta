define endian={{ meta.endian }};
define alignment={{ meta.alignment }};

# Address spaces
define space ram      type=ram_space      size={{ (meta.word_size_bits // 8) | int }}  wordsize=1 default;
define space register type=register_space size=4;

# Register file
# Registers are laid out sequentially: {{ registers | map(attribute='name') | join(', ') }}
{% set reg_size = (meta.word_size_bits // 8) | int %}
define register offset=0x00 size={{ reg_size }} [
{% for reg in registers %}
    {{ reg.name }}{% if not loop.last %}{% endif %}

{% endfor %}
];

{% if registers | selectattr('aliases') | list %}
# Register aliases
{% for reg in registers %}
{% for alias in reg.aliases %}
{% if alias and alias != reg.name %}
define register offset={{ (loop.revindex0 * reg_size) | int }} size={{ reg_size }} [ {{ alias }} ];
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}

# Tokens (instruction bit fields)
{% for width in meta.instruction_sizes_bits %}
define token instr{{ width }}({{ width }})
{% set ns = namespace(first=true) %}
{% for instr in instructions %}
{% if instr.encoding_bits == width %}
{% for field_name, bit_range in instr.bit_fields.items() %}
{% if ns.first %}
    {{ field_name }}{{ width }} = ({{ bit_range.split(':') | reverse | join(',') }})
{% set ns.first = false %}
{% else %}
    {{ field_name }}{{ width }} = ({{ bit_range.split(':') | reverse | join(',') }})
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}
;

{% endfor %}

# Instruction constructors
{% for instr in instructions %}
# {{ instr.mnemonic }}: {{ instr.semantics | truncate(80) }}
{% set display = instr.mnemonic %}
{% if instr.operands %}
{% set display = display + ' ' + (instr.operands | join(', ')) %}
{% endif %}
:{{ display }} is {% if instr.bit_constraints %}{% for field, val in instr.bit_constraints.items() %}{{ field }}{{ instr.encoding_bits }}=0b{{ val }}{% if not loop.last %} & {% endif %}{% endfor %}{% else %}epsilon{% endif %}

{
    {{ instr.pcode_hint if instr.pcode_hint else '# TODO: semantics not extracted' }}
}

{% endfor %}
