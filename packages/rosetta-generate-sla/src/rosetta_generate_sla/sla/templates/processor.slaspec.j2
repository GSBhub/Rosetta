# Auto-generated SLEIGH specification for {{ meta.name }}
# Generated by rosetta — do not hand-edit unless correcting P-code.

define endian={{ meta.endian }};
define alignment={{ meta.alignment }};

# Address spaces
define space ram      type=ram_space      size={{ (meta.word_size_bits // 8) | int }}  wordsize=1 default;
define space register type=register_space size=4;

# Register file
# Registers are laid out sequentially: {{ registers | map(attribute='name') | join(', ') }}
{% set reg_size = (meta.word_size_bits // 8) | int %}
define register offset=0x00 size={{ reg_size }} [
{% for reg in registers %}
    {{ reg.name }}
{% endfor %}
];

# Register aliases: {{ registers | selectattr('aliases') | map(attribute='name') | join(', ') }} have aliases — omitted to avoid duplicate-offset errors in SLEIGH.

# Tokens (instruction bit fields)
{% for width in meta.instruction_sizes_bits %}
{% set tok_ns = namespace(seen_fields=[]) %}
define token instr{{ width }}({{ width }})
{% for instr in instructions %}
{% if instr.encoding_bits == width %}
{% for field_name, bit_range in instr.bit_fields.items() %}
{% if field_name not in tok_ns.seen_fields %}
    {{ field_name }}{{ width }} = ({{ bit_range.split(':') | reverse | join(',') }})
{% set tok_ns.seen_fields = tok_ns.seen_fields + [field_name] %}
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}
    op{{ width }}stub = (0,{{ width - 1 }})
;

{% endfor %}

# Instruction constructors
{% set instr_ns = namespace(stub_id=0) %}
{% for instr in instructions %}
# {{ instr.mnemonic }}: {{ instr.semantics | truncate(80) }}
{% set display = instr.mnemonic %}
{% if instr.operands %}
{% set display = display + ' ' + (instr.operands | join(', ')) %}
{% endif %}
{% if instr.bit_constraints %}
:{{ display }} is {% for field, val in instr.bit_constraints.items() %}{{ field }}{{ instr.encoding_bits }}=0b{{ val }}{% if not loop.last %} & {% endif %}{% endfor %}

{% else %}
:{{ display }} is op{{ instr.encoding_bits }}stub={{ instr_ns.stub_id }}
{% set instr_ns.stub_id = instr_ns.stub_id + 1 %}
{% endif %}
{
    {{ instr.pcode_hint | sanitize_pcode }}
}

{% endfor %}
