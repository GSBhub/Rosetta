<?xml version="1.0" encoding="UTF-8"?>
<!-- Auto-generated compiler spec for {{ meta.name }} -->
<compiler_spec>
  <data_organization>
    <absolute_max_alignment value="0"/>
    <machine_alignment value="{{ meta.alignment }}"/>
    <default_alignment value="{{ meta.alignment }}"/>
    <default_pointer_alignment value="{{ meta.alignment }}"/>
    <pointer_size value="{{ (meta.word_size_bits // 8) | int }}"/>
    <wchar_size value="4"/>
    <short_size value="2"/>
    <integer_size value="4"/>
    <long_size value="{{ (meta.word_size_bits // 8) | int }}"/>
    <long_long_size value="8"/>
    <float_size value="4"/>
    <double_size value="8"/>
    <long_double_size value="8"/>
    <size_alignment_map>
      <entry size="1" alignment="1"/>
      <entry size="2" alignment="2"/>
      <entry size="4" alignment="4"/>
      <entry size="8" alignment="8"/>
    </size_alignment_map>
  </data_organization>

  <stackpointer register="{{ sp_register }}" space="ram"/>

  <default_proto>
    <proto name="__default" extrapop="0" stackshift="0">
      <input>
        <pentry minsize="1" maxsize="{{ (meta.word_size_bits // 8) | int }}">
          <register name="{{ registers[0].name if registers else 'R0' }}"/>
        </pentry>
{% for reg in registers[1:4] %}
        <pentry minsize="1" maxsize="{{ (meta.word_size_bits // 8) | int }}">
          <register name="{{ reg.name }}"/>
        </pentry>
{% endfor %}
      </input>
      <output>
        <pentry minsize="1" maxsize="{{ (meta.word_size_bits // 8) | int }}">
          <register name="{{ registers[0].name if registers else 'R0' }}"/>
        </pentry>
      </output>
      <unaffected>
{% for reg in registers[4:] %}
        <register name="{{ reg.name }}"/>
{% endfor %}
      </unaffected>
    </proto>
  </default_proto>
</compiler_spec>
